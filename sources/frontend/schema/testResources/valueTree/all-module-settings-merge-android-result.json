{
  "product" : {
    "type" : "kmp/lib",
    "platforms" : [
      "JVM",
      "ANDROID",
      "IOS_ARM64"
    ]
  },
  "layout" : "AMPER",
  "aliases" : {
    "jvmAndAndroid" : [
      "JVM",
      "ANDROID"
    ]
  },
  "dependencies(android)" : [
    {
      "groupId(jvmAndAndroid)" : "org.jetbrains.compose.runtime(jvmAndAndroid)",
      "artifactId(jvmAndAndroid)" : "runtime(jvmAndAndroid)",
      "version(jvmAndAndroid)" : "1.4.1(jvmAndAndroid)"
    },
    {
      "groupId(android)" : "androidx.compose.animation(android)",
      "artifactId(android)" : "animation-graphics(android)",
      "version(android)" : "1.4.3(android)"
    }
  ],
  "settings" : {
    "android" : {
      "compileSdk" : "VERSION_33",
      "minSdk" : "VERSION_30",
      "applicationId" : "my-application",
      "namespace" : "com.example.namespace",
      "maxSdk" : "VERSION_33",
      "targetSdk" : "VERSION_33"
    },
    "compose" : {
      "enabled" : "true"
    },
    "jvm" : {
      "mainClass" : "MainKt"
    },
    "junit" : "NONE",
    "kotlin" : {
      "apiVersion" : "1.8",
      "languageVersion" : "1.8",
      "allWarningsAsErrors" : "false",
      "debug" : "false",
      "progressiveMode" : "false",
      "suppressWarnings" : "false",
      "verbose" : "true",
      "freeCompilerArgs" : [
        "-Xinline-classes",
        "-Xxxx"
      ],
      "optIns" : [
        "kotlinx.Experimental"
      ]
    },
    "publishing" : {
      "group" : "org.jetbrains.amper.frontend.without-fragments.yaml",
      "version" : "42-SNAPSHOT"
    },
    "native" : {
      "entryPoint" : "entrypoint-native"
    }
  },
  "repositories" : [
    {
      "id" : "scratch",
      "url" : "https://packages.jetbrains.team/maven/p/amper/amper",
      "publish" : "true",
      "credentials" : {
        "file" : "local.properties",
        "usernameKey" : "tName",
        "passwordKey" : "tPass"
      }
    },
    {
      "url" : "https://packages.jetbrains.team/maven/p/deft/deft"
    }
  ]
}